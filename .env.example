# Order executor: omit for XTS, or set to "mock" for local testing (no broker calls)
ORDER_EXECUTOR=mock

# Market data provider: omit for XTS, or set to "python" for Python sidecar
MARKET_DATA_PROVIDER=python

# --- XTS (used when ORDER_EXECUTOR is not "mock" and MARKET_DATA_PROVIDER is not "python")
XTS_MARKET_DATA_URL=ws://127.0.0.1:8010/ws
XTS_INTERACTIVE_URL=http://127.0.0.1:8001
XTS_APP_KEY=your_app_key
XTS_SECRET_KEY=your_secret_key

# --- Python sidecar (when MARKET_DATA_PROVIDER=python)
PYTHON_MARKET_DATA_SCRIPT=/path/to/market_data.py
MARKET_DATA_SYMBOL=GOLD26
# Optional: skip Python subprocess and use a fixed price for testing
PYTHON_MOCK_PRICE=100.50

# --- Instrument (must match broker format, e.g. exchangeSegment_instrumentId)
DEFAULT_SYMBOL=1_22

# --- Ports
SIGNAL_PORT=5001
DASHBOARD_PORT=3000

# --- Persistence (optional)
# OMS_STATE_PATH=D:\path\to\oms-state.json
# OMS_MAX_STATE_ITEMS=5000
# OMS_UI_STATE_WINDOW=500
# OMS_PERSIST_DEBOUNCE_MS=400
# OMS_DISABLE_PERSIST=1
